# Base de données (SQLite en V1 via l'adaptateur libsql, PostgreSQL prévu ensuite)
DATABASE_URL="file:./dev.db"

# Serveur
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Stockage des photos (voir §7, §12.8). En prod : /app/storage (volume
# docker-compose) servi par le conteneur `storage` sur img.monstres.fbc.fr.
STORAGE_PATH=./storage
IMG_BASE_URL=http://localhost:3000/uploads

# Auth (JWT en cookie httpOnly)
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=access_token
JWT_COOKIE_DOMAIN=localhost
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax

# Connexion Google/Facebook (Phase 11). Sans ces 4 valeurs, les boutons
# "Continuer avec Google/Facebook" redirigent vers /connexion avec un
# message d'erreur clair — le reste de l'app fonctionne normalement.
# Google  : console.cloud.google.com → APIs & Services → Identifiants →
#           ID client OAuth 2.0 (type "Application Web").
#           URI de redirection autorisé : ${APP_URL}/api/v1/auth/google/callback
# Facebook : developers.facebook.com → Mes apps → Facebook Login → Paramètres.
#           URI de redirection OAuth valide : ${APP_URL}/api/v1/auth/facebook/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Emails (Brevo — https://app.brevo.com/settings/keys/api)
# Sans BREVO_API_KEY, les emails sont simplement loggés en console (dev local).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@monstres.fbc.fr
BREVO_SENDER_NAME=Les Monstres
