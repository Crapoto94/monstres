// Les Monstres — schéma de données
// Vocabulaire : "Monstre" côté interface, "Item" côté code/base (voir CLAUDE.md).
// Référence fonctionnelle complète : LES_MONSTRES_cahier_des_charges.md §13.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ItemStatus {
  AVAILABLE
  RESERVED
  COLLECTED
  PENDING_REVIEW
  HIDDEN
  ARCHIVED
}

enum ItemPhotoType {
  LISTING
  COLLECTION
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum VoteType {
  INTERESTING
}

enum ReportType {
  FAKE
  WRONG_LOCATION
  INAPPROPRIATE
  DUPLICATE
  ALREADY_COLLECTED
}

enum ReportStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  NEW_ITEM_NEARBY
  RESERVATION_CREATED
  ITEM_COLLECTED
  BADGE_UNLOCKED
}

enum SettingType {
  STRING
  INTEGER
  FLOAT
  BOOLEAN
  JSON
}

// ─────────────────────────────────────────────────────────────────────────
// Modèles
// ─────────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  password        String
  avatar          String?
  emailVerifiedAt DateTime?
  role            UserRole @default(USER)
  score           Int      @default(0)
  trustScore      Int      @default(100)
  // Consentement notifications email (§9 RGPD : "notifications (email oui/non)").
  emailNotifications Boolean @default(true)
  // Modération de compte (§14, Phase 9) : suspension temporaire vs bannissement
  // définitif, appliqués par un admin. Un login est refusé si l'un des deux est renseigné.
  suspendedAt     DateTime?
  bannedAt        DateTime?

  // Métadonnées de connexion (visibles en admin)
  registrationIp    String?
  registrationUserAgent String?
  registrationOs    String?
  registrationBrowser String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginUserAgent String?
  lastLoginOs       String?
  lastLoginBrowser  String?

  // Onboarding tutorial (Phase 11+)
  onboardingCompletedAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Vérification d'email (Phase 1). TTL configurable via `settings`.
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?

  // Mot de passe oublié (Phase 1). TTL configurable via `settings`.
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  socialAccounts  SocialAccount[]
  items           Item[]
  reservations    Reservation[]
  votes           Vote[]
  comments        Comment[]
  subscriptions   Subscription[]
  notifications   Notification[]
  userBadges      UserBadge[]
  scoringEvents   ScoringEvent[]
  reports         Report[]
  auditLogs       AuditLog[]

  @@map("users")
}

model SocialAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  providerId String
  token      String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("social_accounts")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  items Item[]

  @@map("categories")
}

model Item {
  id           String     @id @default(cuid())
  userId       String
  categoryId   String?
  title        String
  description  String?
  latitude     Float
  longitude    Float
  address      String?
  status       ItemStatus @default(AVAILABLE)
  views        Int        @default(0)
  votesScore   Int        @default(0)
  reservedAt   DateTime?
  collectedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  photos       ItemPhoto[]
  reservations Reservation[]
  votes        Vote[]
  comments     Comment[]
  reports      Report[]
  scoringEvents ScoringEvent[]

  @@index([status])
  @@index([latitude, longitude])
  @@map("items")
}

model ItemPhoto {
  id            String        @id @default(cuid())
  itemId        String
  type          ItemPhotoType @default(LISTING)
  path          String
  thumbnailPath String?
  order         Int           @default(0)
  createdAt     DateTime      @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_photos")
}

model Reservation {
  id        String             @id @default(cuid())
  itemId    String
  userId    String
  status    ReservationStatus  @default(ACTIVE)
  createdAt DateTime           @default(now())
  expiresAt DateTime

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@map("reservations")
}

model Vote {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  type      VoteType @default(INTERESTING)
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId, type])
  @@map("votes")
}

model Comment {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  name      String
  latitude  Float
  longitude Float
  radius    Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  data      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Badge {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String?
  condition   String
  active      Boolean @default(true)

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model ScoringEvent {
  id        String   @id @default(cuid())
  userId    String
  itemId    String?
  type      String
  points    Int
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("scoring_events")
}

model Report {
  id             String       @id @default(cuid())
  itemId         String
  userId         String
  type           ReportType
  reason         String?
  status         ReportStatus @default(PENDING)
  photoLatitude  Float?
  photoLongitude Float?
  createdAt      DateTime     @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // §6.5 : un même utilisateur ne peut signaler un Monstre qu'une fois
  // (peu importe le type) — "signalements distincts" = utilisateurs distincts.
  @@unique([itemId, userId])
  @@map("reports")
}

model Setting {
  id        String      @id @default(cuid())
  key       String      @unique
  value     String
  type      SettingType @default(STRING)
  updatedAt DateTime    @updatedAt

  @@map("settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  data      String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model TutorialPage {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  title     String
  content   String
  icon      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tutorial_pages")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  subject     String
  htmlContent String
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}
