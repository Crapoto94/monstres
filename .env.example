# Variables pour le déploiement via docker-compose.yml (Proxmox).
# Ce fichier N'EST PAS utilisé en développement local : voir
# backend/.env.example et frontend/.env.example pour le dev local sans Docker.

# ── Backend (passé au conteneur via env_file) ──────────────────────────────
# API sur /api/, photos sur /uploads/ — pas de sous-domaine api./img. tant
# qu'ils ne sont pas configurés en DNS (voir PROGRESS.md).
#
# Plusieurs domaines peuvent pointer vers ce même serveur (ex.
# monstres.fbc.fr ET monstres.app) : le SPA appelle toujours l'API en
# chemin relatif (voir VITE_API_URL plus bas), donc il n'y a rien à
# dupliquer ici pour ça. APP_URL/FRONTEND_URL restent un domaine canonique
# unique (utilisé pour les liens dans les emails et les callbacks OAuth
# Google/Facebook, qui n'acceptent qu'une URI de redirection fixe par
# provider — la connexion Google/Facebook ne fonctionnera donc que sur ce
# domaine canonique tant que ça n'est pas rendu dynamique).
DATABASE_URL=file:/app/data/monstres.db
PORT=3000
APP_URL=https://monstres.fbc.fr
FRONTEND_URL=https://monstres.fbc.fr
# Liste séparée par des virgules si plusieurs domaines appellent l'API en
# absolu (le SPA lui-même n'en a pas besoin, voir plus haut).
CORS_ORIGIN=https://monstres.fbc.fr,https://monstres.app

# Volume partagé avec le conteneur `storage` (voir docker-compose.yml)
STORAGE_PATH=/app/storage
IMG_BASE_URL=https://monstres.fbc.fr/uploads

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=access_token
# Laisser VIDE pour un cookie "host-only" qui fonctionne correctement sur
# n'importe quel domaine pointant vers ce serveur (monstres.fbc.fr ET
# monstres.app en même temps, chacun avec sa propre session indépendante).
# Ne renseigner que si un partage de session entre sous-domaines d'un même
# domaine est explicitement voulu (ex. app.exemple.com + api.exemple.com).
JWT_COOKIE_DOMAIN=
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=lax

# Connexion Google/Facebook (Phase 11). Il manque le CLIENT_SECRET Google et
# les deux valeurs Facebook — tant qu'elles sont vides, les boutons de
# connexion externe redirigent proprement vers /connexion avec un message
# d'erreur (le reste de l'app n'est pas affecté).
# URI de redirection à déclarer côté Google/Facebook :
#   https://monstres.fbc.fr/api/v1/auth/google/callback
#   https://monstres.fbc.fr/api/v1/auth/facebook/callback
GOOGLE_CLIENT_ID=664972213673-flovs7g1hj9kilf7e16v28aclia8vphf.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Emails (Brevo — https://app.brevo.com/settings/keys/api). Le domaine
# d'envoi doit avoir ses enregistrements SPF/DKIM/DMARC configurés (§12.2).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@fbc.fr
BREVO_SENDER_NAME=Les Monstres

# Notifications WhatsApp (Meta WhatsApp Cloud API — developers.facebook.com,
# app "WhatsApp Business Platform"). WHATSAPP_TEMPLATE_NAME doit correspondre
# à un message template créé et approuvé dans Meta Business Manager (une
# seule variable de corps : le texte de la notification).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=monstres_notification
WHATSAPP_TEMPLATE_LANGUAGE=fr

# Notifications push (Web Push — fonctionne même app/navigateur fermé, tant
# que le service worker est enregistré ; opt-in explicite depuis le profil,
# aucun moyen technique de l'activer sans action de l'utilisateur). Générer
# une paire de clés avec : npx web-push generate-vapid-keys
# La clé publique est exposée via GET /api/v1/push/public-key (le frontend
# n'a pas besoin de la connaître au build, ça marche donc pareil sur tous
# les domaines qui pointent vers ce serveur).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@fbc.fr

# ── Frontend (build arg, valeur figée au build de l'image) ────────────────
# Chemin RELATIF (pas de domaine) : le navigateur résout `/api/v1` par
# rapport à l'origine de la page — donc ça marche identiquement sur
# n'importe quel domaine pointant vers ce serveur (monstres.fbc.fr,
# monstres.app, ou un futur autre domaine) sans jamais passer par du CORS
# ni casser le cookie de session. Une valeur absolue (https://...) figerait
# l'appli sur un seul domaine, quel que soit celui réellement visité.
VITE_API_URL=/api/v1
