# Variables pour le déploiement via docker-compose.yml (Proxmox).
# Ce fichier N'EST PAS utilisé en développement local : voir
# backend/.env.example et frontend/.env.example pour le dev local sans Docker.

# ── Backend (passé au conteneur via env_file) ──────────────────────────────
# Domaine unique (voir nginx/nginx.conf) : API sur /api/, photos sur
# /uploads/ — pas de sous-domaine api./img. tant qu'ils ne sont pas
# configurés en DNS (voir PROGRESS.md).
DATABASE_URL=file:/app/data/monstres.db
PORT=3000
APP_URL=https://monstres.fbc.fr
FRONTEND_URL=https://monstres.fbc.fr
CORS_ORIGIN=https://monstres.fbc.fr

# Volume partagé avec le conteneur `storage` (voir docker-compose.yml)
STORAGE_PATH=/app/storage
IMG_BASE_URL=https://monstres.fbc.fr/uploads

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=access_token
JWT_COOKIE_DOMAIN=monstres.fbc.fr
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=lax

# Connexion Google/Facebook (Phase 11). Il manque le CLIENT_SECRET Google et
# les deux valeurs Facebook — tant qu'elles sont vides, les boutons de
# connexion externe redirigent proprement vers /connexion avec un message
# d'erreur (le reste de l'app n'est pas affecté).
# URI de redirection à déclarer côté Google/Facebook :
#   https://monstres.fbc.fr/api/v1/auth/google/callback
#   https://monstres.fbc.fr/api/v1/auth/facebook/callback
GOOGLE_CLIENT_ID=664972213673-flovs7g1hj9kilf7e16v28aclia8vphf.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Emails (Brevo — https://app.brevo.com/settings/keys/api). Le domaine
# d'envoi doit avoir ses enregistrements SPF/DKIM/DMARC configurés (§12.2).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@fbc.fr
BREVO_SENDER_NAME=Les Monstres

# Notifications WhatsApp (Meta WhatsApp Cloud API — developers.facebook.com,
# app "WhatsApp Business Platform"). WHATSAPP_TEMPLATE_NAME doit correspondre
# à un message template créé et approuvé dans Meta Business Manager (une
# seule variable de corps : le texte de la notification).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=monstres_notification
WHATSAPP_TEMPLATE_LANGUAGE=fr

# ── Frontend (build arg, valeur figée au build de l'image) ────────────────
VITE_API_URL=https://monstres.fbc.fr/api/v1
