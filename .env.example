# Variables pour le déploiement via docker-compose.yml (Proxmox).
# Ce fichier N'EST PAS utilisé en développement local : voir
# backend/.env.example et frontend/.env.example pour le dev local sans Docker.

# ── Backend (passé au conteneur via env_file) ──────────────────────────────
DATABASE_URL=file:/app/data/monstres.db
PORT=3000
APP_URL=https://api.monstres.fbc.fr
FRONTEND_URL=https://monstres.fbc.fr
CORS_ORIGIN=https://monstres.fbc.fr

# Volume partagé avec le conteneur `storage` (voir docker-compose.yml)
STORAGE_PATH=/app/storage
IMG_BASE_URL=https://img.monstres.fbc.fr

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=access_token
JWT_COOKIE_DOMAIN=.monstres.fbc.fr
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=lax

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Emails (Brevo — https://app.brevo.com/settings/keys/api). Le domaine
# d'envoi doit avoir ses enregistrements SPF/DKIM/DMARC configurés (§12.2).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@monstres.fbc.fr
BREVO_SENDER_NAME=Les Monstres

# ── Frontend (build arg, valeur figée au build de l'image) ────────────────
VITE_API_URL=https://api.monstres.fbc.fr/api/v1
